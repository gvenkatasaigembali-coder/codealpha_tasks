import random

words = ["python", "internship", "codealpha", "mentor", "developer"]

secret_word = random.choice(words)
guessed_letters = []

max_attempts = 6
wrong_attempts = 0

print("WELCOME TO HANGMAN")
print("Guess the word one letter at a time.")
print("You have", max_attempts, "wrong attempts.\n")

while wrong_attempts < max_attempts:

    display_word = ""

    for letter in secret_word:
        if letter in guessed_letters:
            display_word += letter + " "
        else:
            display_word += "_ "

    print("\nWord:", display_word)
    print("Guessed letters:", guessed_letters)
    print("Attempts left:", max_attempts - wrong_attempts)

    if "_" not in display_word:
        print("\nCongratulations!")
        print("You guessed the word:", secret_word)
        break

    guess = input("Enter a letter: ").lower()

    if len(guess) != 1 or not guess.isalpha():
        print("Enter only one alphabet.")
        continue

    if guess in guessed_letters:
        print("You already guessed this letter.")
        continue

    guessed_letters.append(guess)

    if guess in secret_word:
        print("Correct guess!")
    else:
        wrong_attempts += 1
        print("Wrong guess!")

if wrong_attempts == max_attempts:
    print("\nGame Over!")
    print("The correct word was:", secret_word)

print("\nThanks for playing!")